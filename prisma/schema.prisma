generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model income {
  income_id                         String    @id @default(dbgenerated("('INC-'::text || upper(SUBSTRING(md5((random())::text) FROM 1 FOR 8)))")) @db.VarChar(50)
  income_transaction_id             String?   @unique @db.VarChar(100)
  income_source                     String?   @db.VarChar(255)
  income_source_type                String?   @db.VarChar(100)
  income_type                       String?   @db.VarChar(100)
  income_currency                   String?   @db.VarChar(10)
  income_amount                     Decimal?  @db.Decimal(15, 2)
  income_date                       DateTime? @db.Date
  income_frequency                  String?   @db.VarChar(50)
  recurring_income_start_date       DateTime? @db.Date
  recurring_income_frequency_months Int?
  recurring_income_period_years     Int?
  percentage_tax_applied            Decimal?  @db.Decimal(5, 2)
  invoice_date                      DateTime? @db.Date
  payment_terms_days                Int?
  tds_percentage                    Decimal?  @db.Decimal(5, 2)
  created_at                        DateTime? @default(now()) @db.Timestamp(6)
  updated_at                        DateTime? @default(now()) @db.Timestamp(6)
}

model expense {
  expense_id                         String    @id @default(dbgenerated("('EXP-'::text || upper(SUBSTRING(md5((random())::text) FROM 1 FOR 8)))")) @db.VarChar(50)
  expense_transaction_id              String?   @unique @db.VarChar(100)
  expense_destination                String?   @db.VarChar(255)
  expense_destination_type           String?   @db.VarChar(150)
  expense_type                       String?   @db.VarChar(100)
  expense_currency                   String?   @db.VarChar(10)
  expense_amount                     Decimal?  @db.Decimal(15, 2)
  expense_date                       DateTime? @db.Date
  expense_frequency                  String?   @db.VarChar(50)
  recurring_expense_start_date       DateTime? @db.Date
  recurring_expense_frequency_months Int?
  recurring_expense_period_years     Int?
  percentage_tax_applied             Decimal?  @db.Decimal(5, 2)
  supplier_invoice_date              DateTime? @db.Date
  payment_terms_days                 Int?
  tds_percentage                     Decimal?  @db.Decimal(5, 2)
  payment_mode                       String?   @db.VarChar(50)
  created_at                         DateTime? @default(now()) @db.Timestamp(6)
  updated_at                         DateTime? @default(now()) @db.Timestamp(6)
}

model supplier {
  supplier_id                          String    @id @default(dbgenerated("('SUP-'::text || upper(SUBSTRING(md5((random())::text) FROM 1 FOR 8)))")) @db.VarChar(50)
  supplier_code                        String?   @unique @db.VarChar(100)
  supplier_start_date                  DateTime? @default(now()) @db.Date
  supplier_type                        String?   @db.VarChar(100)
  supplier_description                 String?
  supplier_certifications              String?   @db.VarChar(255)
  supplier_organisation_size           String?   @db.VarChar(50)
  supplier_turnover_currency           String?   @db.VarChar(10)
  supplier_turnover                    Decimal?  @db.Decimal(15, 2)
  supplier_turnover_year               Int?
  supplier_employees_for_turnover_year Int?
  supplier_blacklisted                 Boolean?  @default(false)
  supplier_blacklist_date              DateTime? @db.Date
  supplier_headquarter_country         String?   @db.VarChar(100)
  supplier_headquarter_city            String?   @db.VarChar(100)
  supplier_local_address               String?
  supplier_pincode                     String?   @db.VarChar(20)
  supplier_email                       String?   @unique
  supplier_country_code                String?   @db.VarChar(10)
  supplier_telephone                   String?   @db.VarChar(20)
  supplier_linkedin                    String?
  supplier_website                     String?
  supplier_references                  String?
  created_at                           DateTime? @default(now()) @db.Timestamp(6)
  updated_at                           DateTime? @default(now()) @db.Timestamp(6)
  inventories inventory[]

  @@map("supplier")
}

model DataAsset {
  data_id                    String    @id @default(dbgenerated("('DAT-'::text || upper(SUBSTRING(md5((random())::text) FROM 1 FOR 8)))")) @db.VarChar(50)
  data_type                  String?   @db.VarChar(50)
  data_status                String?   @db.VarChar(50)
  data_redundancy            String?   @db.VarChar(50)
  data_storage_medium        String?
  encryption_used            String?   @db.VarChar(100)
  data_behind_firewall       String?   @db.VarChar(20)
  data_content               String?
  data_confidentiality_score Int?
  data_activity              String?   @db.VarChar(255)
  data_owner                 String?   @db.VarChar(255)
  data_users                 String?   @db.VarChar(255)
  data_creation_month        Int?
  data_creation_year         Int?
  data_frequency_type        String?   @db.VarChar(50)
  data_frequency_interval    String?   @db.VarChar(50)
  data_start_date            DateTime? @db.Date
  data_currency_years        Int?
  ip_data                    Boolean?
  data_retention_years       Int?
  recurring_data_size_gb     Decimal?  @db.Decimal(10, 2)
  non_recurring_data_size_gb Decimal?  @db.Decimal(10, 2)
  created_at                 DateTime? @default(now()) @db.Timestamp(6)
  updated_at                 DateTime? @default(now()) @db.Timestamp(6)

  @@map("data_asset")
}

model inventory {

  inventory_id String @id @default(dbgenerated("('INV-'::text || upper(SUBSTRING(md5((random())::text) FROM 1 FOR 8)))")) @db.VarChar(50)

  item_number String? @unique @db.VarChar(100)

  inventory_name String? @db.VarChar(255)

  inventory_description String?

  division_name String? @db.VarChar(150)

  subdivision_name String? @db.VarChar(150)

  inventory_owner String? @db.VarChar(150)

  quantity Int?

  estimated_lead_time_days Int?

  inventory_price Decimal? @db.Decimal(15, 2)

  inventory_currency String? @db.VarChar(10)

  supplier_name String? @db.VarChar(255)

  supplier_id String? @db.VarChar(50)
  supplier supplier? @relation(fields: [supplier_id], references: [supplier_id])
  
  inventory_category String? @db.VarChar(100)

  inventory_status String? @db.VarChar(100)

  inventory_type String? @db.VarChar(100)

  inventory_location String?

  inventory_storage_type String? @db.VarChar(100)

  inventory_purchase_date DateTime? @db.Date

  inventory_expiry_date DateTime? @db.Date

  inventory_condition String? @db.VarChar(100)

  inventory_serial_number String? @unique @db.VarChar(150)

  inventory_barcode String? @unique @db.VarChar(150)

  inventory_reorder_level Int?

  inventory_maximum_stock Int?

  inventory_minimum_stock Int?

  inventory_unit String? @db.VarChar(50)

  inventory_usage_frequency String? @db.VarChar(100)

  inventory_last_updated DateTime? @default(now()) @db.Timestamp(6)

  created_at DateTime? @default(now()) @db.Timestamp(6)

  updated_at DateTime? @default(now()) @db.Timestamp(6)

}

model activity {

  activity_id             String    @id @default(dbgenerated("('ACT-'::text || upper(SUBSTRING(md5((random())::text) FROM 1 FOR 8)))")) @db.VarChar(50)

  activity_name           String    @db.VarChar(255)

  activity_description    String?

  related_module          String?   @db.VarChar(100)

  related_record_id       String?   @db.VarChar(100)

  activity_owner          String?   @db.VarChar(255)

  activity_status         String?   @db.VarChar(50)

  start_date              DateTime? @db.Date

  target_completion_date  DateTime? @db.Date

  actual_completion_date  DateTime? @db.Date

  target_quantity         Int?

  actual_quantity         Int?

  efficiency_percentage   Decimal?  @db.Decimal(5,2)

  remarks                 String?

  created_at              DateTime? @default(now())

  updated_at              DateTime? @updatedAt
}

model department {

  department_id String @id @default(dbgenerated("('DEP-'::text || upper(SUBSTRING(md5((random())::text) FROM 1 FOR 8)))")) @db.VarChar(50)

  department_name String @unique @db.VarChar(255)

  department_head String? @db.VarChar(255)

  department_description String?

  department_status String? @default("Active") @db.VarChar(50)

  department_location String? @db.VarChar(255)

  created_at DateTime? @default(now()) @db.Timestamp(6)

  updated_at DateTime? @updatedAt @db.Timestamp(6)
}