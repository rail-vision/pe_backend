generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NEW — User model for auth
model User {
  id         String   @id @default(uuid())
  firstName  String
  lastName   String
  email      String   @unique
  password   String
  role       UserRole @default(VIEWER)
  department String   @default("general")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum UserRole {
  ADMIN
  MANAGER
  VIEWER
}

// EXISTING MODELS — unchanged
model Asset {
  id                             String   @id @default(uuid())
  assetId                        String   @unique
  assetCode                      String
  ownerId                        String
  assetName                      String
  assetDescription               String
  purchaseDate                   DateTime
  assetCurrency                  String
  purchaseValue                  Float
  currentValue                   Float
  depreciation                   Float
  assetLife                      Int
  assetLiquidityLevel            Float
  annualAssetUsageLevel          Float
  assetManufacturer              String
  assetManufacturingCountry      String
  assetWarrantyPeriod            Int
  assetMaintenanceContract       Boolean
  assetMaintenanceContractor     String?
  assetAnnualMaintenanceCost     Float?
  expectedMeanTimeBetweenFailure Float
  assetCategory                  String
  assetDimensions                String
  assetWeight                    String
  assetLocationGPS               String
  assetLocationAddress           String
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt
}

model People {
  id                     String       @id @default(uuid())
  personId               String       @unique
  employeeCode           String?
  personName             String
  personStatus           PersonStatus
  designation            String
  designationDescription String?
  workStatus             WorkStatus
  personAddress          String
  country                String
  functionalUnit         String
  startDate              DateTime
  workEmail              String       @unique
  personalEmail          String?
  workPhone              String
  expertise              String
  workPeriod             WorkPeriod
  driversLicense         Boolean
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
}

model Template {
  id           String   @id @default(uuid())
  templateName String
  module       String
  fields       Json
  createdAt    DateTime @default(now())
}

model employees {
  id         Int       @id @default(autoincrement())
  name       String?   @db.VarChar(255)
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

model students {
  id         Int       @id @default(autoincrement())
  name       String?   @db.VarChar(255)
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

enum PersonStatus {
  FULL_TIME
  PART_TIME
}

enum WorkStatus {
  ACTIVE
  NON_ACTIVE
}

enum WorkPeriod {
  DAY_ONLY
  NIGHT_ONLY
  FLEXIBLE
}